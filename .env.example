# Вариант 1: ключ для codex внутри buyer-контейнера.
OPENAI_API_KEY=

# Опционально: кастомный endpoint совместимый с OpenAI API.
OPENAI_BASE_URL=https://api.openai.com/v1

# Опционально: organization id.
OPENAI_ORG_ID=

# Вариант 2 (OAuth): абсолютный путь на host к auth.json для Codex CLI.
# Пример: /Users/<you>/.codex/auth.json
# Файл монтируется только в runtime и не попадает в image.
CODEX_AUTH_JSON_PATH=

# Абсолютный путь на host к user-buyer-info.md с постоянной информацией о пользователе.
# Пример: /Users/<you>/Documents/user-buyer-info.md
# Файл монтируется только в runtime и не попадает в image.
USER_BUYER_INFO_PATH=

# Режим sandbox для codex внутри buyer.
# Для доступа к browser-sidecar по CDP нужен danger-full-access.
CODEX_SANDBOX_MODE=danger-full-access

# Модель codex для запуска агентных шагов.
CODEX_MODEL=gpt-5.5

# Reasoning effort для Codex CLI. Для максимальной скорости используем none.
CODEX_REASONING_EFFORT=none

# Отключить image generation tool в Codex CLI для generic buyer-flow.
CODEX_IMAGE_GENERATION=disabled

# Отключить reasoning summary в ответах Codex CLI.
CODEX_REASONING_SUMMARY=none

# Generic buyer-flow не должен тратить время на web search.
CODEX_WEB_SEARCH=disabled

# Стратегия выбора модели для generic buyer-flow: single или fast_then_strong.
BUYER_MODEL_STRATEGY=single

# Быстрая модель для первого прохода при BUYER_MODEL_STRATEGY=fast_then_strong.
BUYER_FAST_CODEX_MODEL=gpt-5.4-mini

# Сильная модель для fallback; пусто означает CODEX_MODEL или gpt-5.5.
BUYER_STRONG_CODEX_MODEL=

# Окно восстановления CDP в секундах (preflight + recovery шага).
CDP_RECOVERY_WINDOW_SEC=20

# Интервал между retry-попытками CDP в миллисекундах.
CDP_RECOVERY_INTERVAL_MS=500

# Каталог трассировки buyer (примонтирован с host через /workspace).
BUYER_TRACE_DIR=/workspace/.tmp/buyer-observability

# Внутренний URL eval_service для micro-ui proxy.
EVAL_SERVICE_BASE_URL=http://eval_service:8090

# Базовый URL eval_service, доступный из buyer-контейнера для callback.
EVAL_CALLBACK_BASE_URL=http://eval_service:8090

# Модель Codex judge для eval_service.
EVAL_JUDGE_MODEL=gpt-5.5

# Размер окна baseline для eval dashboard.
EVAL_BASELINE_WINDOW=5

# Длина превью prompt в callback-событиях.
BUYER_PROMPT_PREVIEW_CHARS=2000

# Длина хвоста stdout/stderr codex в trace.
BUYER_STREAM_TAIL_CHARS=4000

# Сколько последних браузерных действий (из cdp_tool) добавлять в trace.
BUYER_BROWSER_ACTIONS_TAIL=40

# Домены, где buyer пытается SberId scripts-first (CSV).
SBERID_ALLOWLIST=litres.ru,brandshop.ru,kuper.ru,samokat.ru,okko.tv

# Сколько раз можно запросить новый auth-пакет (дополнительно к первой попытке).
SBERID_AUTH_RETRY_BUDGET=1

# Каталог TS-скриптов авторизации внутри buyer-контейнера.
AUTH_SCRIPTS_DIR=/app/scripts

# Таймаут запуска auth-скрипта (сек).
AUTH_SCRIPT_TIMEOUT_SEC=90

# Домены, где buyer пытается быстрый purchase-скрипт до generic codex-flow (CSV).
PURCHASE_SCRIPT_ALLOWLIST=litres.ru

# Таймаут запуска purchase-скрипта (сек).
PURCHASE_SCRIPT_TIMEOUT_SEC=120

# Backend состояния buyer: postgres для docker compose, memory для быстрых локальных unit-тестов.
STATE_BACKEND=postgres

# Postgres для долговременного состояния задач, сессий, событий, ответов и артефактов.
POSTGRES_DB=buyer
POSTGRES_USER=buyer
POSTGRES_PASSWORD=buyer
DATABASE_URL=postgresql://buyer:buyer@postgres:5432/buyer
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=5
