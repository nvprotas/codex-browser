{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BuyerAgentStepOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "message", "order_id", "payment_evidence", "profile_updates"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["needs_user_input", "completed", "failed"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "order_id": {
      "type": ["string", "null"]
    },
    "payment_evidence": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["source", "url"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["litres_payecom_iframe", "brandshop_yoomoney_sberpay_redirect"]
        },
        "url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "profile_updates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
